// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.generated/client"
}

datasource db {
  provider = "postgresql"
}

model Ranking {
  id        Int      @id @default(autoincrement())
  userName  String
  score     Float    // 小数点5桁などのタイム
  stage     Int      // 1, 2, 0(Total)
  createdAt DateTime @default(now())
}