// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Ranking {
  id        Int      @id @default(autoincrement())
  userName  String
  score     Float
  stage     Int
  createdAt DateTime @default(now())
}
